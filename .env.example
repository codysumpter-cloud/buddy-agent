# Buddy Agent local config
BUDDY_HOME=~/.buddy-agent
BUDDY_MEMORY_FILE=~/.buddy_agent/memory.json

# Disabled by default for safe local installs
BUDDY_ENABLE_GATEWAY=false
BUDDY_ENABLE_SANDBOX=false
BUDDY_RESTRICTED_INTEGRATIONS_ENABLED=false

# Retrieval / operator posture
BUDDY_RETRIEVAL_ENABLED=true
BUDDY_KNOWLEDGE_PATHS=
BUDDY_OPERATOR_PROFILE=buddy-alpha-plus

# Omni routing
BUDDY_OMNI_ENABLED=false
BUDDY_OMNI_BASE_URL=http://127.0.0.1:8799/api/omni
BUDDY_OMNI_TOKEN_ENV=PRISMBOT_API_TOKEN
BUDDY_OMNI_MODEL=omni-core:phase2
BUDDY_OMNI_TIMEOUT_SECONDS=90
BUDDY_OMNI_FALLBACK_TO_LOCAL=true
